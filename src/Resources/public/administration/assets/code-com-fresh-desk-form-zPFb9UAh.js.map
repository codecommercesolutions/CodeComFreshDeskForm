{% block sw_cms_element_freshdesk_standard_form %}
<div class="sw-cms-el-freshdesk-standard-form">
    <h3 v-if="element.config.formTitle.value" class="form-title">
        {{ element.config.formTitle.value }}
    </h3>
    
    <div class="sw-cms-el-form-contact-form-group two-items">
        <mt-text-field
            :label="element.config.firstNameLabel.value"
            :model-value="element.config.firstNameLabel.value"></mt-text-field>

        <mt-text-field
            :label="element.config.lastNameLabel.value"
            :model-value="element.config.lastNameLabel.value"></mt-text-field>
    </div>

    <div class="sw-cms-el-form-contact-form-group two-items">
        <mt-text-field
            :label="element.config.emailLabel.value"
            :model-value="element.config.emailLabel.value"></mt-text-field>

        <mt-text-field
            :label="element.config.phoneLabel.value"
            :model-value="element.config.phoneLabel.value"></mt-text-field>
    </div>

    <mt-select
        :label="element.config.typeLabel.value"
        :model-value="'Request'"
        :options="typeOptions"></mt-select>

    <mt-text-field
        :label="element.config.subjectLabel.value"
        :model-value="element.config.subjectLabel.value"></mt-text-field>

    <mt-textarea
        :label="element.config.descriptionLabel.value"
        :model-value="element.config.descriptionLabel.value"></mt-textarea>

    <p class="sw-cms-el-form-contact__note">
        * Required fields
    </p>
</div>
{% endblock %}
