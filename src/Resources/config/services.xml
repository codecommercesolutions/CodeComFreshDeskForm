<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults autowire="true" autoconfigure="true" public="false"/>

        <service id="CodeCom\FreshdeskForm\Service\FreshdeskService"/>

        <service id="CodeCom\FreshdeskForm\Storefront\Controller\CustomFormController" public="true">
            <argument key="$formSubmissionRepository" type="service" id="freshdesk_form_submission.repository"/>
            <argument key="$formApiDataRepository" type="service" id="freshdesk_form_api_data.repository"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
            <tag name="controller.service_arguments"/>
        </service>

        <service id="CodeCom\FreshdeskForm\Core\Api\FreshdeskApiController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
            <tag name="controller.service_arguments"/>
        </service>

        <service id="CodeCom\FreshdeskForm\Core\Api\FreshdeskLookupController" public="true">
            <argument key="$formApiDataRepository" type="service" id="freshdesk_form_api_data.repository"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
            <tag name="controller.service_arguments"/>
        </service>

        <service id="CodeCom\FreshdeskForm\Subscriber\CmsPageLoaderSubscriber">
            <argument key="$formApiDataRepository" type="service" id="freshdesk_form_api_data.repository"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="CodeCom\FreshdeskForm\Subscriber\FormSubmissionSubscriber">
            <argument key="$formSubmissionRepository" type="service" id="freshdesk_form_submission.repository"/>
            <argument key="$formApiDataRepository" type="service" id="freshdesk_form_api_data.repository"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="CodeCom\FreshdeskForm\Core\Api\FreshdeskTicketsController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
            <tag name="controller.service_arguments"/>
        </service>

        <!-- Entity Definitions -->
        <service id="CodeCom\FreshdeskForm\Core\Content\FormSubmission\FormSubmissionDefinition">
            <tag name="shopware.entity.definition" entity="freshdesk_form_submission"/>
        </service>

        <service id="CodeCom\FreshdeskForm\Core\Content\FormApiData\FormApiDataDefinition">
            <tag name="shopware.entity.definition" entity="freshdesk_form_api_data"/>
        </service>

        <!-- Scheduled Task: 24-hour Freshdesk API data sync -->
        <service id="CodeCom\FreshdeskForm\Schedule\FreshdeskApiSyncTask">
            <tag name="shopware.scheduled.task"/>
        </service>

        <service id="CodeCom\FreshdeskForm\Schedule\FreshdeskApiSyncTaskHandler">
            <argument key="$scheduledTaskRepository" type="service" id="scheduled_task.repository"/>
            <argument key="$formApiDataRepository" type="service" id="freshdesk_form_api_data.repository"/>
            <tag name="messenger.message_handler"/>
        </service>
    </services>
</container>
