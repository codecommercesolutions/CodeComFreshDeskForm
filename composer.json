{
    "name": "codecom/freshdesk-form",
    "description": "CodeCom FreshDesk Form Integration",
    "version": "3.0.0",
    "type": "shopware-platform-plugin",
    "license": "proprietary",
    "authors": [
        {
            "name": "CodeCommerce Solutions",
            "homepage": "https://www.codecommercesolutions.com"
        }
    ],
    "require": {
        "shopware/core": ">=6.7.0.0 < 6.8.0.0",
        "shopware/administration": ">=6.7.0.0 < 6.8.0.0",
        "shopware/storefront": ">=6.7.0.0 < 6.8.0.0"
    },
    "extra": {
        "shopware-plugin-class": "CodeCom\\FreshDeskForm\\CodeComFreshDeskForm",
        "plugin-icon": "src/Resources/config/plugin.png",
        "copyright": "(c) by CodeCommerce Solutions",
        "label": {
            "de-DE": "Freshdesk Form Integration",
            "en-GB": "Freshdesk Form Integration"
        },
        "description": {
            "de-DE": "Mit diesem Plugin für Shopware, können Sie unterschiedliche Formulare erstellen",
            "en-GB": "With this plugin it is relatively easy to generate forms"
        },
        "manufacturerLink": {
            "de-DE": "https://www.codecommercesolutions.com",
            "en-GB": "https://www.codecommercesolutions.com"
        },
        "supportLink": {
            "de-DE": "https://www.codecommercesolutions.com/contact/",
            "en-GB": "https://www.codecommercesolutions.com/contact/"
        }
    },
    "autoload": {
        "psr-4": {
            "CodeCom\\FreshDeskForm\\": "src/"
        }
    },
    "require-dev": {
        "nunomaduro/phpinsights": "^2.14",
        "phpstan/phpstan": "^2.1"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": false,
            "dealerdirect/phpcodesniffer-composer-installer": false
        }
    }
}
